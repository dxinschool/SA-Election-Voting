<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #111111; color: #ffffff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
    a { text-decoration: none; }

    .container { width: 100%; max-width: 1000px; padding: 24px; }

    .header { position: relative; display: flex; align-items: center; justify-content: space-between; padding: 16px 0; margin-bottom: 16px; }
    .header-left h1 { font-size: 1.25rem; font-weight: 600; color: #ffffff; }
    .header-center { position: absolute; left: 50%; transform: translateX(-50%); }
    .header-center .countdown { display: flex; align-items: center; gap: 8px; font-size: 1.1rem; font-weight: 600; color: #ffffff; letter-spacing: 0.02em; }
    .header-center .countdown .closes-label { font-size: 0.7rem; color: #71717a; font-weight: 500; margin-right: 6px; letter-spacing: 0.04em; }
    .header-center .countdown .num { color: #ffffff; font-weight: 600; min-width: 22px; text-align: center; }
    .header-center .countdown .sep { color: #52525b; }
    .header-center .countdown .unit { display: flex; flex-direction: column; align-items: center; }
    .header-center .countdown .unit .num { line-height: 1; }
    .header-center .countdown .unit .unit-label { font-size: 0.6rem; color: #52525b; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }
    .header-center .countdown.ended { color: #ef4444; }
    .header-center .countdown.ended .num { color: #ef4444; }
    .header-right { display: flex; align-items: center; gap: 20px; }
    .header a { font-size: 0.875rem; font-weight: 500; color: #a3a3a3; transition: color 0.15s; }
    .header a:hover { color: #ffffff; }

    .student-info { text-align: right; }
    .student-info .name { font-size: 0.875rem; font-weight: 600; color: #ffffff; }
    .student-info .meta { font-size: 0.75rem; color: #a3a3a3; margin-top: 2px; }

    .hero { text-align: center; margin: 48px 0 40px; }
    .hero h2 { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 8px; }
    .hero p { font-size: 1rem; color: #a3a3a3; }

    .success-banner { text-align: center; padding: 14px 16px; background: rgba(34,197,94,0.08); border: 1px solid rgba(34,197,94,0.2); border-radius: 8px; font-size: 0.875rem; font-weight: 500; color: #22c55e; margin-bottom: 24px; }

    .card-grid { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
    .dash-card { background: #09090b; border: 1px solid #262626; border-radius: 8px; padding: 24px; width: 100%; max-width: 300px; display: flex; flex-direction: column; transition: border-color 0.15s; }
    .dash-card:hover { border-color: #404040; }

    .dash-card .card-icon { width: 40px; height: 40px; border-radius: 8px; display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
    .dash-card .card-icon.purple { background: rgba(138,93,244,0.12); color: #8A5DF4; }
    .dash-card .card-icon.yellow { background: rgba(251,191,36,0.12); color: #fbbf24; }
    .dash-card .card-icon.gray { background: rgba(255,255,255,0.05); color: #a3a3a3; }
    .dash-card .card-icon svg { width: 20px; height: 20px; }

    .dash-card .card-label { font-size: 0.7rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
    .dash-card .card-title { font-size: 1.25rem; font-weight: 700; color: #ffffff; margin-bottom: 2px; }
    .dash-card .card-meta { font-size: 0.8rem; color: #a3a3a3; margin-bottom: 16px; }
    .dash-card .card-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 0.75rem; font-weight: 500; padding: 4px 10px; border-radius: 9999px; margin-bottom: 16px; width: fit-content; }
    .dash-card .card-badge.pending { background: rgba(251,191,36,0.1); color: #fbbf24; border: 1px solid rgba(251,191,36,0.15); }
    .dash-card .card-badge.voted { background: rgba(34,197,94,0.1); color: #22c55e; border: 1px solid rgba(34,197,94,0.15); }
    .dash-card .card-badge .dot { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
    .dash-card .card-stat { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: #ffffff; margin-bottom: 2px; }
    .dash-card .card-stat-label { font-size: 0.75rem; color: #71717a; margin-bottom: 16px; }

    .dash-card .card-btn { width: 100%; height: 40px; border: 1px solid #262626; border-radius: 6px; font-size: 0.85rem; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; background: #111111; color: #ffffff; text-decoration: none; display: flex; align-items: center; justify-content: center; gap: 6px; transition: background 0.15s; }
    .dash-card .card-middle { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    .dash-card .card-btn:hover { background: #262626; }
    .dash-card .card-btn.primary { border-color: #8A5DF4; color: #8A5DF4; }
    .dash-card .card-btn.primary:hover { background: rgba(138,93,244,0.1); }
    .dash-card .card-btn svg { width: 16px; height: 16px; }

    @media (max-width: 768px) {
      .container { padding: 16px; }
      .header-left h1 { font-size: 1rem; }
      .header-center .countdown { font-size: 0.85rem; gap: 4px; }
      .header-center .countdown .closes-label { font-size: 0.6rem; margin-right: 4px; }
      .header-center .countdown .num { min-width: 18px; }
      .header-center .countdown .unit .unit-label { font-size: 0.5rem; }
      .hero { margin: 28px 0 24px; }
      .hero h2 { font-size: 1.5rem; }
      .hero p { font-size: 0.85rem; }
      .student-info .meta { font-size: 0.65rem; }
      .card-grid { flex-direction: column; align-items: center; }
      .dash-card { max-width: 100%; }
    }
    @media (max-width: 480px) {
      .header-center .countdown { font-size: 0.7rem; gap: 2px; }
      .header-center .countdown .closes-label { display: none; }
      .header-center .countdown .num { min-width: 16px; font-size: 0.75rem; }
      .header-center .countdown .unit .unit-label { font-size: 0.45rem; }
      .header-center .countdown .sep { font-size: 0.7rem; }
      .student-info .meta { font-size: 0.6rem; }
      .student-info .name { font-size: 0.75rem; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="header-left"><h1><%= title %></h1></div>
      <div class="header-center"><div class="countdown" id="countdown"></div></div>
      <div class="header-right">
        <div class="student-info"><div class="name"><%= student.SNAME %></div><div class="meta"><%= student.SID %></div></div>
        <a href="/logout">Sign Out</a>
      </div>
    </div>

    <div class="hero">
      <h2>Welcome back, <%= student.SNAME.split(' ')[0] %></h2>
      <p>Your voice matters — make it count</p>
    </div>

    <% if (success) { %><div class="success-banner">&#10003; Your vote has been recorded.</div><% } %>

    <div class="card-grid">
      <div class="dash-card">
        <div class="card-icon purple">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
        </div>
        <div class="card-middle">
          <div class="card-label">Candidates</div>
          <div class="card-stat"><%= candidates.length %></div>
          <div class="card-stat-label">Running for election</div>
        </div>
        <a href="/candidates?view=1" class="card-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          View Profiles
        </a>
      </div>

      <div class="dash-card">
        <div class="card-icon yellow">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <div class="card-middle">
          <div class="card-label">My Vote</div>
          <% if (isCandidate) { %>
            <div class="card-title">Candidate</div>
            <div class="card-meta">You are running in this election</div>
            <div class="card-badge" style="background:rgba(138,93,244,0.1);color:#8A5DF4;border:1px solid rgba(138,93,244,0.15);"><span class="dot"></span> Candidate</div>
          <% } else if (!votingEnabled) { %>
            <div class="card-title">Voting Disabled</div>
            <div class="card-meta">Voting is currently paused by the administrator</div>
            <div class="card-badge" style="background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.15);"><span class="dot"></span> Disabled</div>
          <% } else { %>
            <div class="card-title"><%= voted ? 'Vote Cast' : 'Cast Your Vote' %></div>
            <div class="card-meta">Ranked-choice ballot</div>
            <% if (voted) { %><div class="card-badge voted"><span class="dot"></span> You've voted</div>
            <% } else { %><div class="card-badge pending"><span class="dot"></span> Vote pending</div><% } %>
          <% } %>
        </div>
        <% if (isCandidate) { %>
        <a href="/candidate-panel" class="card-btn" style="border-color:#8A5DF4;color:#8A5DF4;">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          My Candidate Panel
        </a>
        <% } else if (votingEnabled) { %>
        <a href="/candidates" class="card-btn <%= voted ? '' : 'primary' %>">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          <%= voted ? 'Change Vote' : 'Vote Now' %>
        </a>
        <% } %>
      </div>

      <div class="dash-card">
        <div class="card-icon gray">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        </div>
        <div class="card-middle">
          <div class="card-label">Results</div>
          <div class="card-title">Live Tally</div>
          <div class="card-meta">Instant-runoff rounds</div>
        </div>
        <a href="/results" class="card-btn">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          View Results
        </a>
      </div>
    </div>
  </div>

  <script>
    (function() {
      var banner = document.querySelector('.success-banner');
      if (banner) setTimeout(function() { banner.style.transition = 'opacity .5s'; banner.style.opacity = '0'; setTimeout(function() { banner.style.display = 'none'; }, 500); }, 3000);
    })();
  </script>
  <script>
    (function() {
      var el = document.getElementById('countdown');
      if (!el) return;
      var deadline = new Date('<%= deadline %>').getTime();
      function update() {
        var now = Date.now();
        var diff = deadline - now;
        if (diff <= 0) {
          el.className = 'countdown ended';
          el.innerHTML = 'Polls closed';
          document.dispatchEvent(new Event('pollsclosed'));
          return;
        }
        var d = Math.floor(diff / 86400000);
        var h = Math.floor((diff % 86400000) / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.innerHTML =
          '<span class="closes-label">Polls close in</span>' +
          '<div class="unit"><span class="num">' + d + '</span><span class="unit-label">days</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(h) + '</span><span class="unit-label">hrs</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(m) + '</span><span class="unit-label">min</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(s) + '</span><span class="unit-label">sec</span></div>';
      }
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      update();
      setInterval(update, 1000);
    })();
  </script>
</body>
</html>
