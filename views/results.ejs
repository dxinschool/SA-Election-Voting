<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Results</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #111111; color: #ffffff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
    a { text-decoration: none; }

    .container { width: 100%; max-width: 1000px; padding: 24px; }

    .header { position: relative; display: flex; align-items: center; justify-content: space-between; padding: 16px 0; margin-bottom: 16px; }
    .header-left h1 { font-size: 1.25rem; font-weight: 600; }
    .header-center { position: absolute; left: 50%; transform: translateX(-50%); }
    .header-center .countdown { display: flex; align-items: center; gap: 8px; font-size: 1.1rem; font-weight: 600; color: #ffffff; letter-spacing: 0.02em; }
    .header-center .countdown .closes-label { font-size: 0.7rem; color: #71717a; font-weight: 500; margin-right: 6px; letter-spacing: 0.04em; }
    .header-center .countdown .num { color: #ffffff; font-weight: 600; min-width: 22px; text-align: center; }
    .header-center .countdown .sep { color: #52525b; }
    .header-center .countdown .unit { display: flex; flex-direction: column; align-items: center; }
    .header-center .countdown .unit .num { line-height: 1; }
    .header-center .countdown .unit .unit-label { font-size: 0.6rem; color: #52525b; text-transform: uppercase; letter-spacing: 0.08em; margin-top: 2px; }
    .header-center .countdown.ended { color: #ef4444; }
    .header-center .countdown.ended .num { color: #ef4444; }
    .header-right { display: flex; align-items: center; gap: 20px; }
    .header a { font-size: 0.875rem; font-weight: 500; color: #a3a3a3; transition: color 0.15s; }
    .header a:hover { color: #ffffff; }

    .hero { text-align: center; margin: 48px 0 40px; }
    .hero h2 { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 8px; }
    .hero p { font-size: 1rem; color: #a3a3a3; }

    .winner-card { display: none; background: linear-gradient(135deg, rgba(138,93,244,0.08), rgba(76,29,149,0.08)); border: 1px solid #8A5DF4; border-radius: 12px; padding: 28px; text-align: center; margin-bottom: 32px; }
    .winner-card.show { display: block; }
    .winner-label { font-size: 0.7rem; font-weight: 600; color: #8A5DF4; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .winner-name { font-size: 1.6rem; font-weight: 700; color: #ffffff; margin-bottom: 2px; }
    .winner-position { font-size: 0.85rem; color: #a3a3a3; margin-bottom: 12px; }
    .winner-votes { font-size: 0.85rem; color: #71717a; }

    .stats-row { display: flex; gap: 12px; margin-bottom: 32px; flex-wrap: wrap; }
    .stat-box { flex: 1; min-width: 100px; background: #09090b; border: 1px solid #262626; border-radius: 8px; padding: 16px; text-align: center; }
    .stat-box .num { font-size: 1.5rem; font-weight: 700; color: #ffffff; line-height: 1; margin-bottom: 4px; }
    .stat-box .label { font-size: 0.7rem; color: #71717a; text-transform: uppercase; letter-spacing: 0.06em; }

    .round-card { background: #09090b; border: 1px solid #262626; border-radius: 8px; padding: 20px; margin-bottom: 12px; }
    .round-header { font-size: 0.85rem; font-weight: 600; color: #a3a3a3; margin-bottom: 12px; }
    .round-vote { display: flex; align-items: center; gap: 12px; margin-bottom: 8px; }
    .round-vote .cname { flex: 1; font-size: 0.85rem; color: #ffffff; }
    .round-vote .cvotes { font-size: 0.8rem; color: #a3a3a3; min-width: 30px; text-align: right; }
    .round-bar-bg { flex: 0 0 120px; height: 8px; background: #1a1a1a; border-radius: 4px; overflow: hidden; }
    .round-bar-fill { height: 100%; border-radius: 4px; background: #8A5DF4; transition: width 0.35s; }

    .empty-state { text-align: center; padding: 48px 24px; color: #71717a; font-size: 0.9rem; }

    .bottom-nav { display: flex; justify-content: center; margin-top: 32px; padding-bottom: 32px; }
    .back-btn { height: 44px; padding: 0 24px; border: 1px solid #262626; border-radius: 6px; font-size: 0.875rem; font-weight: 500; font-family: 'Inter', sans-serif; cursor: pointer; background: #111111; color: #ffffff; display: inline-flex; align-items: center; justify-content: center; gap: 6px; text-decoration: none; transition: background 0.15s; }
    .back-btn:hover { background: #262626; }
    .back-btn svg { width: 16px; height: 16px; }

    @media (max-width: 768px) {
      .container { padding: 16px; }
      .hero { margin: 28px 0 24px; }
      .hero h2 { font-size: 1.5rem; }
      .stats-row { gap: 8px; }
      .stat-box { min-width: calc(50% - 8px); }
      .stat-box .num { font-size: 1.2rem; }
      .round-bar-bg { flex: 0 0 80px; }
      .winner-name { font-size: 1.3rem; }
      .bottom-nav { margin-top: 24px; }
    }
    @media (max-width: 480px) {
      .round-bar-bg { flex: 0 0 60px; }
      .round-vote { gap: 8px; }
      .winner-card { padding: 20px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="header-left"><h1><%= title %></h1></div>
      <div class="header-center"><div class="countdown" id="countdown"></div></div>
      <div class="header-right">
        <a href="/home">Dashboard</a>
        <a href="/logout">Sign Out</a>
      </div>
    </div>

    <div class="hero">
      <h2>Election Results</h2>
      <p>Instant-runoff tally — updated in real time</p>
    </div>

    <% var electionOver = new Date(deadline).getTime() <= Date.now(); %>
    <% if (winner) { %>
      <div class="winner-card show" id="winner-card">
        <div class="winner-label">&#9733; <%= electionOver ? 'Winner' : 'Leading' %></div>
        <div class="winner-name"><%= winner %></div>
        <div class="winner-position">SBA President</div>
      </div>
    <% } else { %>
      <div class="winner-card" id="winner-card"></div>
    <% } %>

    <% if (rounds && rounds.length > 0) { %>
      <div class="stats-row">
        <div class="stat-box"><div class="num"><%= totalVoters %></div><div class="label">Voters</div></div>
        <div class="stat-box"><div class="num"><%= rounds[0].votes.reduce(function(s, v) { return s + v.count; }, 0) %></div><div class="label">Votes Cast</div></div>
        <div class="stat-box"><div class="num"><%= rounds.length %></div><div class="label">Rounds</div></div>
        <div class="stat-box"><div class="num"><%= candidates.length %></div><div class="label">Candidates</div></div>
        <div class="stat-box"><div class="num"><%= blankVotes %></div><div class="label">Blank</div></div>
      </div>

      <% rounds.forEach(function(round, rIdx) { %>
        <div class="round-card">
          <div class="round-header">Round <%= rIdx + 1 %><% if (round.eliminated) { %> &mdash; <span style="color:#ef4444;"><%= round.eliminated %> eliminated</span><% } %></div>
          <% var maxCount = Math.max.apply(Math, round.votes.map(function(v) { return v.count; })); %>
          <% round.votes.forEach(function(v) { %>
            <div class="round-vote">
              <span class="cname"><%= v.name %></span>
              <div class="round-bar-bg"><div class="round-bar-fill" style="width:<%= maxCount > 0 ? (v.count / maxCount * 100) : 0 %>%"></div></div>
              <span class="cvotes"><%= v.count %></span>
            </div>
          <% }); %>
        </div>
      <% }); %>
    <% } else { %>
      <div class="empty-state">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:48px;height:48px;color:#52525b;margin:0 auto 16px;display:block;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
        No votes have been cast yet.<br><span style="font-size:0.8rem;color:#52525b;">Results will appear here once students start voting.</span>
      </div>
    <% } %>

    <div class="bottom-nav">
      <a href="/home" class="back-btn">
        <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Dashboard
      </a>
    </div>
  </div>

  <script>
    (function() {
      var el = document.getElementById('countdown');
      if (!el) return;
      var deadline = new Date('<%= deadline %>').getTime();
      function update() {
        var now = Date.now();
        var diff = deadline - now;
        if (diff <= 0) {
          el.className = 'countdown ended';
          el.innerHTML = 'Polls closed';
          document.dispatchEvent(new Event('pollsclosed'));
          // Reload page so server re-renders with Winner label
          setTimeout(function() { location.reload(); }, 500);
          return;
        }
        var d = Math.floor(diff / 86400000);
        var h = Math.floor((diff % 86400000) / 3600000);
        var m = Math.floor((diff % 3600000) / 60000);
        var s = Math.floor((diff % 60000) / 1000);
        el.innerHTML =
          '<span class="closes-label">Polls close in</span>' +
          '<div class="unit"><span class="num">' + d + '</span><span class="unit-label">days</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(h) + '</span><span class="unit-label">hrs</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(m) + '</span><span class="unit-label">min</span></div>' +
          '<span class="sep">:</span>' +
          '<div class="unit"><span class="num">' + pad(s) + '</span><span class="unit-label">sec</span></div>';
      }
      function pad(n) { return n < 10 ? '0' + n : '' + n; }
      update();
      setInterval(update, 1000);
    })();

    (function() {
      var el = document.getElementById('winner-card');
      if (!el) return;
      document.addEventListener('pollsclosed', function() {
        el.classList.add('show');
      });
    })();
  </script>
</body>
</html>
