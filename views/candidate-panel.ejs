<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — My Candidate Profile</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #111111; color: #ffffff; min-height: 100vh; display: flex; flex-direction: column; align-items: center; }
    a { text-decoration: none; color: inherit; }

    .container { width: 100%; max-width: 700px; padding: 24px; }

    .header { display: flex; align-items: center; justify-content: space-between; padding: 16px 0; margin-bottom: 24px; }
    .header h1 { font-size: 1.25rem; font-weight: 600; }
    .header-right { display: flex; gap: 20px; }
    .header a { font-size: 0.875rem; color: #a3a3a3; }
    .header a:hover { color: #ffffff; }

    .profile-card { background: #09090b; border: 1px solid #262626; border-radius: 12px; padding: 32px; text-align: center; margin-bottom: 20px; }
    .avatar {
      width: 80px; height: 80px; border-radius: 50%; background: #8A5DF4;
      display: flex; align-items: center; justify-content: center;
      font-size: 2rem; font-weight: 700; color: #ffffff;
      margin: 0 auto 16px;
    }
    .profile-name { font-size: 1.5rem; font-weight: 700; margin-bottom: 2px; }
    .profile-pos { font-size: 0.85rem; color: #a3a3a3; margin-bottom: 16px; }

    .card { background: #09090b; border: 1px solid #262626; border-radius: 10px; padding: 28px; margin-bottom: 20px; }
    .card-title { font-size: 0.7rem; font-weight: 600; color: #71717a; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }

    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 0.8rem; font-weight: 500; color: #a3a3a3; margin-bottom: 6px; }
    .form-group textarea {
      width: 100%; padding: 10px 12px;
      background: #111111; border: 1px solid #262626; border-radius: 6px;
      font-size: 0.85rem; font-family: 'Inter', sans-serif;
      color: #ffffff; outline: none; min-height: 100px; resize: vertical;
    }
    .form-group textarea:focus { border-color: #8A5DF4; }

    .form-row { display: flex; gap: 12px; }
    .form-row .form-group { flex: 1; }

    .member-item {
      display: flex; align-items: center; gap: 12px;
      padding: 10px 0; border-bottom: 1px solid #262626;
    }
    .member-item:last-child { border-bottom: none; }
    .member-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: rgba(138,93,244,0.12); color: #8A5DF4;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; font-weight: 600; flex-shrink: 0;
    }
    .member-info { flex: 1; }
    .member-info .name { font-size: 0.85rem; font-weight: 600; }
    .member-info .role { font-size: 0.75rem; color: #71717a; margin-top: 1px; }

    .btn {
      height: 40px; padding: 0 24px; border: none; border-radius: 6px;
      font-size: 0.85rem; font-weight: 500; font-family: 'Inter', sans-serif;
      cursor: pointer; transition: background 0.15s;
    }
    .btn-primary { background: #8A5DF4; color: #ffffff; text-decoration: none; display: inline-flex; align-items: center; }
    .btn-primary:hover { background: #7c3aed; }
    .btn-outline { background: #111111; border: 1px solid #262626; color: #ffffff; text-decoration: none; display: inline-flex; align-items: center; }
    .btn-outline:hover { background: #262626; }
    .btn-small { height: 32px; padding: 0 14px; font-size: 0.75rem; }
    .btn-danger { background: #ef4444; color: #ffffff; }
    .btn-danger:hover { background: #dc2626; }

    .success-msg {
      font-size: 0.85rem; color: #22c55e; text-align: center; margin-bottom: 16px;
      padding: 12px; background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.2); border-radius: 6px;
    }
    .error-msg {
      font-size: 0.85rem; color: #ef4444; text-align: center; margin-bottom: 16px;
      padding: 12px; background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.2); border-radius: 6px;
    }

    .empty-state { font-size: 0.85rem; color: #71717a; padding: 8px 0; }
    .divider { height: 1px; background: #262626; margin: 20px 0; }

    @media (max-width: 480px) {
      .container { padding: 16px; }
      .profile-card { padding: 24px 16px; }
      .card { padding: 20px; }
      .form-row { flex-direction: column; gap: 0; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>My Candidate Profile</h1>
      <div class="header-right">
        <a href="/home">Dashboard</a>
        <a href="/candidates?view=1">Candidates</a>
        <a href="/logout">Sign Out</a>
      </div>
    </div>

    <% if (success) { %><div class="success-msg"><%= success %></div><% } %>
    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <div class="profile-card">
      <div class="avatar"><%= candidate.CNAME.charAt(0) %></div>
      <div class="profile-name"><%= candidate.CNAME %></div>
    </div>

    <div class="card">
      <div class="card-title">My Platform / Description</div>
      <% if (candidate.DESC) { %>
        <div style="font-size:0.9rem;color:#d4d4d8;line-height:1.6;background:#111111;border:1px solid #262626;border-radius:8px;padding:16px 20px;margin-bottom:16px;"><%= candidate.DESC %></div>
      <% } %>
      <form method="POST" action="/candidate-panel/description">
        <div class="form-group">
          <textarea id="description" name="description" placeholder="Tell voters about your platform, goals, and why you're running..."><%= candidate.DESC || '' %></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Update Description</button>
      </form>
    </div>

    <div class="card">
      <div class="card-title">Campaign Members</div>
      <% if (members && members.length > 0) { %>
        <% members.forEach(function(m) { %>
          <div class="member-item">
            <div class="member-avatar"><%= m.MNAME.charAt(0) %></div>
            <div class="member-info">
              <div class="name"><%= m.MNAME %></div>
              <div class="role"><%= m.POSITION || '—' %></div>
            </div>
            <form method="POST" action="/candidate-panel/member/delete" onsubmit="return confirm('Remove <%= m.MNAME %> from your team?')">
              <input type="hidden" name="member_id" value="<%= m.ID %>">
              <button type="submit" class="btn btn-danger btn-small">Remove</button>
            </form>
          </div>
        <% }); %>
        <div class="divider"></div>
      <% } else { %>
        <div class="empty-state">No campaign members yet.</div>
        <div class="divider"></div>
      <% } %>

      <div class="card-title" style="margin-top:0;">Add Campaign Member</div>
      <form method="POST" action="/candidate-panel/member/add">
        <div class="form-row">
          <div class="form-group">
            <label for="mname">Full Name</label>
            <input type="text" id="mname" name="mname" placeholder="e.g. John Doe" required style="width:100%;height:44px;padding:8px 12px;background:#111111;border:1px solid #262626;border-radius:6px;font-size:0.85rem;font-family:'Inter',sans-serif;color:#ffffff;outline:none;">
          </div>
          <div class="form-group">
            <label for="role">Role</label>
            <input type="text" id="role" name="role" placeholder="e.g. Campaign Manager" style="width:100%;height:44px;padding:8px 12px;background:#111111;border:1px solid #262626;border-radius:6px;font-size:0.85rem;font-family:'Inter',sans-serif;color:#ffffff;outline:none;">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Add Member</button>
      </form>
    </div>

    <div style="display:flex;gap:12px;justify-content:center;padding-bottom:32px;flex-wrap:wrap;">
      <a href="/candidate/<%= candidate.SLUG %>" class="btn btn-outline">View Public Profile</a>
      <a href="/results" class="btn btn-outline">View Results</a>
    </div>
  </div>
</body>
</html>
