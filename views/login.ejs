<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Login</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', sans-serif;
      background: #111111;
      color: #ffffff;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    a { text-decoration: none; }

    .form-container { width: 100%; max-width: 448px; }

    .header-text { text-align: center; margin-bottom: 32px; }
    .header-text h1 { font-size: 1.5rem; font-weight: 600; letter-spacing: -0.025em; margin-bottom: 4px; }
    .header-text p { font-size: 0.875rem; font-weight: 500; color: #a3a3a3; }

    .form-group { margin-bottom: 16px; }
    .form-group label { display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 8px; }
    .form-group input {
      width: 100%; height: 44px; padding: 8px 12px;
      background: #111111; border: 1px solid #262626; border-radius: 6px;
      font-size: 0.75rem; font-weight: 500; font-family: 'Inter', sans-serif;
      color: #ffffff; outline: none; transition: border-color 0.2s;
    }
    .form-group input:focus { border-color: #404040; }
    .form-group input::placeholder { color: #a3a3a3; }

    .btn {
      width: 100%; height: 44px; padding: 8px 16px;
      border: none; border-radius: 6px;
      font-size: 0.875rem; font-weight: 500; font-family: 'Inter', sans-serif;
      cursor: pointer; transition: background 0.2s;
    }
    .btn-primary { background: #8A5DF4; color: #ffffff; }
    .btn-primary:hover { background: #7c3aed; }
    .btn-primary:active { transform: scale(0.98); }
    .btn-outline {
      background: #111111; border: 1px solid #262626; color: #ffffff;
      display: flex; align-items: center; justify-content: center; text-decoration: none;
    }
    .btn-outline:hover { background: #262626; }

    .separator { display: flex; align-items: center; gap: 16px; margin: 16px 0; }
    .separator-line { flex: 1; height: 1px; background: #262626; }
    .separator-text { font-size: 0.75rem; color: #a3a3a3; padding: 0 12px; }

    .footer-text { text-align: center; margin-top: 16px; font-size: 0.75rem; color: #a3a3a3; user-select: none; }
    .footer-text a { color: inherit; text-decoration: underline; text-underline-offset: 4px; cursor: pointer; }
    .footer-text a:hover { color: #8A5DF4; }

    .error-msg {
      font-size: 0.8rem; color: #ef4444; text-align: center; margin-bottom: 16px;
      padding: 10px; background: rgba(239,68,68,0.08);
      border: 1px solid rgba(239,68,68,0.15); border-radius: 6px;
    }

    @media (max-width: 480px) {
      .form-container { padding: 0 16px; }
      .header-text h1 { font-size: 1.25rem; }
      .header-text p { font-size: 0.8rem; }
    }
  </style>
</head>
<body>
  <div class="form-container">
    <div class="header-text">
      <h1><%= title %></h1>
      <p>Enter your Student ID to vote</p>
    </div>

    <% if (error) { %><div class="error-msg"><%= error %></div><% } %>

    <form method="POST" action="/login">
      <div class="form-group">
        <label for="sid">Student ID</label>
        <input type="text" id="sid" name="sid" placeholder="e.g. SBA-2401" required>
      </div>
      <button type="submit" class="btn btn-primary">Sign In</button>
    </form>

    <div class="separator">
      <div class="separator-line"></div>
      <span class="separator-text">or</span>
      <div class="separator-line"></div>
    </div>

    <a href="/results" class="btn btn-outline">View Results</a>

    <div class="footer-text">
      <a href="/results">View Election Results →</a>
    </div>
  </div>
</body>
</html>
